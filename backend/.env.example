DJANGO_ENV=development
SECRET_KEY=replace-with-a-long-random-secret-key-at-least-50-characters
DEBUG=False

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
PGBOUNCER_TRANSACTION_MODE=True
DB_SSL_REQUIRE=True
DB_CONN_MAX_AGE=0

EMAIL_ENCRYPTION_KEY=replace-with-fernet-key
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/google/callback
GOOGLE_OAUTH_FRONTEND_REDIRECT_URI=https://your-domain.com/bulk-email

AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_IMAGE_MODEL_ID=amazon.titan-image-generator-v2:0
IMAGE_PROVIDER=openai #bedrock
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_BASE_URL=https://api.openai.com/v1/images/generations
OPENAI_IMAGE_QUALITY=low
TRANSCRIBE_S3_BUCKET=replace-with-transcribe-media-bucket
TRANSCRIBE_OUTPUT_S3_BUCKET=
TRANSCRIBE_S3_PREFIX=transcribe
TRANSCRIBE_LANGUAGE_CODE=en-US
TRANSCRIBE_MAX_UPLOAD_MB=50
TRANSCRIBE_POLL_SECONDS=2
TRANSCRIBE_TIMEOUT_SECONDS=180
TRANSCRIBE_DATA_ACCESS_ROLE_ARN=arn:aws:iam::123456789012:role/TranscribeDataAccessRole
VIDEO_CONVERT_MAX_UPLOAD_MB=500
VIDEO_CONVERT_R2_OBJECT_PREFIX=video-convert
VIDEO_CONVERT_R2_UPLOAD_URL_TTL=900
VIDEO_CONVERT_R2_DOWNLOAD_URL_TTL=600

SES_FROM_EMAIL=noreply@torensa.com
SES_VERIFICATION_URL=https://torensa.com/verify-email
TOOL_METADATA_DIR=backend/metadata

RAPIDAPI_KEY=replace-with-your-rapidapi-key
